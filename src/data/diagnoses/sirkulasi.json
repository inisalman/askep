{
  "category": "Sirkulasi",
  "description": "Diagnosis terkait sistem sirkulasi dan kardiovaskular",
  "diagnoses": {
    "D.0007": {
      "code": "D.0007",
      "name": "Gangguan Sirkulasi Spontan",
      "definition": "ketidakmampuan untuk mempertahankan sirkulasi yang adekuat untuk menunjang kehidupan",
      "type": "Aktual",
      "signs_and_symptoms": {
        "subjective": ["Tidak berespon (unrespon)"],
        "objective": ["Frekuensi nadi < 50 kali/menit atau > 150 kali/menit", "Tekanan darah sistolik < 60 mmHg atau > 200 mmHg", "Frekuensi napas < 6 kali/menit atau > 30 kali/menit", "Kesadaran menurun atau tidak sadar"]
      },
      "related_factors": ["Abnormalitas kelistrikan jantung", "Abnormalitas struktur jantung", "Penurunan fungsi ventrikel"],
      "expected_outcomes": {
        "code": "L.02015",
        "name": "Sirkulasi spontan meningkat",
        "criteria": ["Tingkat kesadaran meningkat", "Frekuensi nadi membaik", "Tekanan darah membaik", "Frekuensi napas membaik"]
      },
      "interventions": [
        {"code": "I.02038", "name": "Manajemen Defibrilasi"},
        {"code": "I.03139", "name": "Resusitasi Cairan"},
        {"code": "I.02083", "name": "Resusitasi Jantung Paru"}
      ]
    },
    "D.0008": {
      "code": "D.0008",
      "name": "Penurunan Curah Jantung",
      "definition": "ketidakmampuan jantung memompa darah untuk memenuhi kebutuhan metabolisme tubuh",
      "type": "Aktual",
      "signs_and_symptoms": {
        "perubahan_irama_jantung": {"subjective": ["Palpitasi (dada terasa berdebar kencang)"], "objective": ["Bradikardia/takikardia", "Gambar EKG Aritmia atau gangguan konduksi"]},
        "perubahan_preload": {"subjective": ["Lelah"], "objective": ["Edema", "Distensi vena jugularis", "CVP meningkat/menurun", "Hepatomegali"]},
        "perubahan_afterload": {"subjective": ["Dispnea (sesak napas)"], "objective": ["Tekanan darah meningkat/menurun", "Nadi perifer teraba lemah", "CRT > 3 detik", "Oliguria", "Warna kulit pucat dan/atau sianosis"]},
        "perubahan_kontraktilitas": {"subjective": ["Paroxysmal nocturnal dyspnea (PND)", "Ortopnea", "Batuk"], "objective": ["Terdengar suara jantung S3 dan/atau S4", "Ejection fraction (EF) menurun"]}
      },
      "related_factors": ["Perubahan irama jantung", "Perubahan preload", "Perubahan afterload", "Perubahan kontraktilitas"],
      "expected_outcomes": {
        "code": "L.02008",
        "name": "Curah jantung meningkat",
        "criteria": ["Kekuatan nadi perifer meningkat", "Ejection fraction (EF) meningkat", "Palpitasi menurun", "Bradikardia/takikardia menurun", "Lelah menurun", "Edema menurun", "Dispnea menurun", "Oliguria menurun"]
      },
      "interventions": [
        {"code": "I.02075", "name": "Perawatan jantung"},
        {"code": "I.02076", "name": "Perawatan jantung akut"}
      ]
    },
